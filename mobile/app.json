    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#3d2b1f"
      },
      "package": "com.oc.characters"
    },
    "plugins": [
      "expo-file-system",
      "expo-document-picker",
      "expo-asset",
      "expo-font"
    ]
  }
}
